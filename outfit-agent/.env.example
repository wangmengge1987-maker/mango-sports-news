# 穿搭助手 环境变量配置
# 复制此文件为 .env 并填入你的 Key

# DeepSeek API Key（已有，在 Claude 设置里那个）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Stability AI API Key（去 https://platform.stability.ai 注册免费拿）
STABILITY_API_KEY=sk-your-stability-api-key

# PushPlus Token（已有，和 sports-agent 用同一个）
PUSHPLUS_TOKEN=your-pushplus-token

# ImgURL 图床（去 https://imgurl.org 注册，后台获取 UID + Token）
IMGURL_UID=your-imgurl-uid
IMGURL_TOKEN=your-imgurl-token

# 城市（用于查天气）
CITY=广州
